# ──────────────────────────────────────
# Voice Bot Widget — Configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────

# ── Azure OpenAI (required for AI chat) ──────────────
# Get these from your Azure OpenAI resource in the Azure Portal.
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# LLM deployment name (must match your Azure deployment, e.g. gpt-4o-mini, gpt-4.1-mini)
LLM_MODEL=gpt-4o-mini

# ── Server ────────────────────────────────────────────
PORT=3800

# Knowledge-base directory (default: ./server/knowledge-base)
# On EC2 use an absolute path, e.g. /home/ubuntu/voice-bot-widget/server/knowledge-base
KB_DIR=./server/knowledge-base

# System prompt override (optional — leave blank to use tenant prompts)
SYSTEM_PROMPT=

# ── Whisper (optional — for server-side transcription) ──
WHISPER_MODEL=

# ── Groww Trading API (optional) ─────────────────────
# Option 1: Paste your access token directly (generate from Groww dashboard)
GROWW_ACCESS_TOKEN=

# Option 2: Auto-generate token using API Key + Secret
#   Get these from https://groww.in/trade-api/api-keys
GROWW_API_KEY=
GROWW_API_SECRET=

# ── Bajaj Broking API (optional) ─────────────────────
BAJAJ_ACCESS_TOKEN=
